# ─────────────────────────────────────────────────────────────
# QA Automation Framework — Environment Configuration
# ─────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# ⚠️  NEVER commit .env to git — it's in .gitignore
# ─────────────────────────────────────────────────────────────

# ── Target URLs ────────────────────────────────────────────────
BASE_URL=https://www.ocus.com
CONTACT_URL=https://help.ocus.com/hc/en-us/requests/new

# ── CI Flag (set automatically by GitHub Actions) ──────────────
CI=false

# ── Test Execution Timeouts (milliseconds) ─────────────────────
TEST_TIMEOUT=60000
ACTION_TIMEOUT=10000
EXPECT_TIMEOUT=10000
NAVIGATION_TIMEOUT=30000

# ── Performance Thresholds (milliseconds) ─────────────────────
MAX_PAGE_LOAD_TIME=5000
MAX_DOM_CONTENT_LOADED=3000
MAX_API_RESPONSE_TIME=2000

# ── Visual Testing ─────────────────────────────────────────────
# Pixel diff ratio tolerance (0.05 = 5%)
VISUAL_DIFF_THRESHOLD=0.05

# ── Retry Configuration ────────────────────────────────────────
RETRIES_CI=2
RETRIES_LOCAL=0

# ── Optional: Staging Environment ─────────────────────────────
# Uncomment and set these when testing against staging
# BASE_URL=https://staging.ocus.com
# CONTACT_URL=https://staging-help.ocus.com/hc/en-us/requests/new
